{
  "UseFakeAdapters": true,
  "ConnectionStrings": {
    "Formicae": "Host=localhost;Port=5432;Database=formicae;Username=formicae;Password=formicae"
  },
  "OpenHands": {
    "DefaultModel": "openhands/claude-sonnet-4",
    "LlmApiKeySecretName": "openhands-llm-api-key",
    "Shell": "/bin/sh",
    "BootstrapCommand": "pip install -q uv && uv tool install openhands --python 3.12 && export PATH=\"/root/.local/bin:$PATH\"",
    "Command": "openhands --headless --json --override-with-envs -t \"$FORMICAE_TASK_PROMPT\""
  },
  "KubernetesJobs": {
    "Namespace": "formicae",
    "Image": "python:3.12-slim",
    "WorkspaceVolumeClaim": "formicae-workspaces"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
